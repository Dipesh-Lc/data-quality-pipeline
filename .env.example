#  Environment Variables - copy to .env and fill in values
#  Never commit .env to source control.


# Database 
#-----------------------------------------------------------------------
# Option A: single connection string (recommended - most hosting providers
# give one URL to paste in)
# DB_URL=postgresql://pipeline_user:pipeline_pass@localhost:5432/dqpipeline

# Option B: individual parts (used when DB_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dqpipeline
DB_USER=pipeline_user
DB_PASSWORD=pipeline_pass

#  Pipeline 
PIPELINE_ENV=development        # development | production
LOG_LEVEL=INFO

#  Optional overrides 
# HOLIDAYS_API_YEAR=2023
# HOLIDAYS_API_COUNTRIES=GB,DE,FR,US
